# OpenClaw Content Factory 配置文件
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env

# ============================================
# 飞书配置（可选）
# ============================================
# 飞书群组 Chat ID，用于绑定 Agent 到指定群组
# 格式：oc_xxx
FEISHU_CHAT_ID=

# ============================================
# API Keys（可选，也可安装后在对应目录配置）
# ============================================

# Tavily 搜索 API Key
# 获取地址：https://tavily.com
TAVILY_API_KEY=

# 硅基流动 API Key（用于抖音文案提取等）
# 获取地址：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=

# ============================================
# 微信公众号配置（可选）
# ============================================
# 获取地址：https://mp.weixin.qq.com
WECHAT_APPID=
WECHAT_SECRET=